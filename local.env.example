# Repository default local environment template.
# Fill these in with your own values or leave them blank while you manage secrets elsewhere.
# If you prefer to keep the real file outside the repo, replace this file with a symlink to that secure location:
#   rm local.env
#   ln -s /path/to/secure/local.env local.env
# Optionally run `git update-index --skip-worktree local.env` after linking to avoid git reporting changes.

export GEMINI_API_KEY=""
export GOOGLE_API_KEY=""
# If you use Vertex AI instead of the Gemini Developer API, provide these as well:
export GOOGLE_CLOUD_PROJECT=""
export GOOGLE_CLOUD_LOCATION="us-central1"
# Optional default model to save time when running the CLI:
export GEMINI_MODEL="gemini-2.5-flash"
